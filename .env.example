# Copy to .env in this folder (repo root). Never commit .env.

CLOUDFLARE_ACCOUNT_ID=e30350dfd5bf9e1a9ca03dc4fdf3b247

# Create at: https://dash.cloudflare.com/profile/api-tokens
# REQUIRED permissions (custom token — include ALL zones in account):
#   • Account → Cloudflare Pages → Edit
#   • Zone → Zone → Read → All zones
#   • Zone → DNS → Edit → All zones
# Optional (auto-create zone if missing):
#   • Zone → Zone → Edit → All zones
CLOUDFLARE_API_TOKEN=

# Per-site build vars are set automatically from sites.registry.json during deploy.
# AdSense — create two Display ad units at https://adsense.google.com (Ads → By ad unit).
# Turn OFF Auto ads for satoshi-calc.com so only these manual slots show.
# VITE_ADSENSE_CLIENT=ca-pub-1132338970019438
# VITE_ADSENSE_SLOT_FOOTER=9490641503
# VITE_ADSENSE_SLOT_CONTENT=8950595776
# Then: node scripts/sync-github-secrets.mjs  (or add same names as GitHub Actions secrets)
