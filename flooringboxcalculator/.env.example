VITE_SITE_URL=https://flooringboxcalculator.com
# VITE_BASE_PATH=/
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google AdSense — paste your publisher ID from AdSense → Sites → Get code
# VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# Keep false until AdSense approves flooringboxcalculator.com:
# VITE_ADSENSE_ENABLED=true

# After approval, create ad units in AdSense and paste slot IDs:
# VITE_ADSENSE_SLOT_CONTENT=1234567890
# VITE_ADSENSE_SLOT_FOOTER=0987654321
# VITE_ADSENSE_SLOT_SIDEBAR=1122334455

# Deploy: add the same vars to repo root .env OR Cloudflare Pages → Environment variables
# Then: npm run deploy -- flooringboxcalculator
