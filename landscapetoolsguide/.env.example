VITE_SITE_URL=https://landscapetoolsguide.com

# Affiliate signup URLs — paste your tracked links after approval (see README.md)
# Falls back to vendor homepage when unset.
# VITE_AFFILIATE_JOBBER=https://getjobber.com/...?via=YOUR_ID
# VITE_AFFILIATE_HOUSECALLPRO=https://housecallpro.com/...?partner=YOUR_ID
# VITE_AFFILIATE_LMN=https://golmn.com/...
# VITE_AFFILIATE_SERVICE_AUTOPILOT=https://serviceautopilot.com/...

# Google AdSense — paste your publisher ID from AdSense → Sites → Get code
# VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# Keep false until AdSense approves landscapetoolsguide.com:
# VITE_ADSENSE_ENABLED=true

# After approval, create ad units in AdSense and paste slot IDs:
# VITE_ADSENSE_SLOT_CONTENT=1234567890
# VITE_ADSENSE_SLOT_FOOTER=0987654321
