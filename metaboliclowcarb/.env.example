VITE_SITE_URL=https://metaboliclowcarb.com

# AdSense — same publisher ID as other sites (repo root .env):
# VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# Keep false until AdSense approves metaboliclowcarb.com:
# VITE_ADSENSE_ENABLED=true

# After approval, create ad units in AdSense and paste slot IDs:
# VITE_ADSENSE_SLOT_CONTENT=1234567890
# VITE_ADSENSE_SLOT_FOOTER=0987654321
# VITE_ADSENSE_SLOT_SIDEBAR=1122334455

# Deploy: npm run deploy -- metaboliclowcarb
