# Copy to .env.local for local development (optional)
# Build deploys via Cloudflare when project/** changes on main.
VITE_SITE_URL=https://satoshi-calc.com
VITE_BASE_PATH=/

# Cloudflare deploy uses repo root .env:
#   CLOUDFLARE_ACCOUNT_ID
#   CLOUDFLARE_API_TOKEN

# Google Analytics 4 (optional)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Display ads (optional — leave blank until approved) ---

# Google AdSense (https://adsense.google.com)
# Publisher ID is in index.html. Disable Auto ads in AdSense (use manual units only).
# Create two Display ad units, then set slot IDs as GitHub secrets and redeploy:
# VITE_ADSENSE_CLIENT=ca-pub-1132338970019438
# VITE_ADSENSE_SLOT_FOOTER=1234567890
# VITE_ADSENSE_SLOT_CONTENT=0987654321

# A-Ads (https://aads.com)
# VITE_AADS_UNIT_ID=123456
# VITE_AADS_SIZE=728x90
