# Copy to .env.local for local development (optional)
# Build deploys to Cloudflare Pages when project/** changes on main.
VITE_SITE_URL=https://satoshi-calc.com
VITE_BASE_PATH=/

# Cloudflare deploy uses repo root .env:
#   CLOUDFLARE_ACCOUNT_ID
#   CLOUDFLARE_API_TOKEN

# Google Analytics 4 — https://analytics.google.com → Admin → Data streams
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Setup: node scripts/setup-google-analytics.mjs G-XXXXXXXXXX

# --- Display ads (optional — leave blank until approved) ---

# Google AdSense (https://adsense.google.com)
# Site status must be "Ready" before enabling. Keep ads.txt / client ID for authorization.
# Disable Auto ads in AdSense dashboard (manual units only).
# VITE_ADSENSE_ENABLED=true
# VITE_ADSENSE_CLIENT=ca-pub-1132338970019438
# VITE_ADSENSE_SLOT_FOOTER=9490641503
# VITE_ADSENSE_SLOT_CONTENT=8950595776

# A-Ads (https://aads.com)
# VITE_AADS_UNIT_ID=123456
# VITE_AADS_SIZE=728x90
