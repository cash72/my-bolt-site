# Copy to .env.local for local development (optional)
VITE_SITE_URL=https://satoshi-calc.com
VITE_BASE_PATH=/

# Google Analytics 4 (optional)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Display ads (optional — leave blank until approved) ---

# Google AdSense (https://adsense.google.com)
# Apply with satoshi-calc.com — educational converter + guides usually qualify.
# After approval, create ad units and paste IDs here:
# VITE_ADSENSE_CLIENT=ca-pub-1132338970019438
# VITE_ADSENSE_SLOT_FOOTER=1234567890
# VITE_ADSENSE_SLOT_CONTENT=0987654321

# A-Ads — crypto-friendly (https://aads.com) — good fallback if AdSense declines crypto
# Create an ad unit for https://satoshi-calc.com/ then paste the unit ID:
# VITE_AADS_UNIT_ID=123456
# VITE_AADS_SIZE=728x90

# Affiliate URLs — replace with tracking links when approved
# VITE_AFFILIATE_COLDCARD=https://coldcard.com/?aff=YOUR_CODE
# VITE_AFFILIATE_JADE=https://blockstream.com/jade/?ref=YOUR_CODE
# VITE_AFFILIATE_BITBOX=https://bitbox.swiss/bitbox02/?ref=YOUR_CODE
# VITE_AFFILIATE_START9=https://start9.com/?ref=YOUR_CODE
# VITE_AFFILIATE_UMBREL=https://umbrel.com/?ref=YOUR_CODE
# VITE_AFFILIATE_SEEDPLATE=https://coldcard.com/docs/seedplate
